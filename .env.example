# Copy to .env.local and fill in values.

# Registrum demo key used by the /api/demo route handler.
# Must start with reg_live_ (Registrum API key format).
# Only ONE active key with label "registrum-website-demo" should exist in Supabase at a time.
# Generate: cd ../ch-enrichment-api && python scripts/create_demo_key.py
# Manage: cd ../ch-enrichment-api && python scripts/manage_keys.py list
# If the key is lost, deactivate the old one in Supabase first, then regenerate.
REGISTRUM_DEMO_API_KEY=reg_live_<32-hex-chars>

# Required for key provisioning (POST /api/register)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
RESEND_API_KEY=

# Required for payments (Stripe)
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRO_PRICE_ID=price_...
