# Staging environment template — placeholders only, NO real secrets.
# Copy to the Vercel STAGING project's env (Preview/Staging scope), or to
# .env.local when running the staging build locally. All values here point at
# the STAGING Supabase project and Stripe TEST mode — never production.
#
# Real values live in the Vercel staging project settings and
# C:\Users\eugen\.claude\credentials.md — do not commit them.

# ── Registrum API demo keys (staging) ────────────────────────────────────────
# Generate against the staging API; must start with reg_live_.
REGISTRUM_DEMO_API_KEY=reg_live_<staging-demo-key>
REGISTRUM_DEMO_PRO_KEY=reg_live_<staging-demo-pro-key>
REGISTRUM_API_KEY=reg_live_<staging-quickstart-key>

# ── Supabase (STAGING project: nsbsdpnwlyktzjpzoori) ─────────────────────────
SUPABASE_URL=https://nsbsdpnwlyktzjpzoori.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<staging-service-role-key>

# ── Email (Resend) ───────────────────────────────────────────────────────────
RESEND_API_KEY=<resend-test-key>

# ── Stripe (TEST MODE ONLY — sk_test_ / whsec_ / price_ test IDs) ─────────────
STRIPE_SECRET_KEY=sk_test_<staging>
STRIPE_WEBHOOK_SECRET=whsec_<staging-subscriptions>
STRIPE_REPORT_WEBHOOK_SECRET=whsec_<staging-report>
STRIPE_WEB_PRICE_ID=price_<test-web>
STRIPE_PRO_PRICE_ID=price_<test-pro>
STRIPE_REPORT_PRICE_ID=price_<test-report>

# ── Dashboard magic-link signing ─────────────────────────────────────────────
DASHBOARD_SECRET=<staging-dashboard-secret>

# ── Telegram alerts (optional in staging) ────────────────────────────────────
TELEGRAM_BOT_TOKEN=<optional>
TELEGRAM_CHAT_ID=<optional>

# ── Anthropic (only if a route needs it) ─────────────────────────────────────
ANTHROPIC_API_KEY=<optional>

# ── Sentry (R4) — leave UNSET to keep error reporting dormant ─────────────────
# SENTRY_DSN=
